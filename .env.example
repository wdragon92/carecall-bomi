# ============================================================
# 돌봄콜 AI — 환경 변수
# 사용법: PowerShell> Copy-Item .env.example .env  → .env에 실제 값 입력
# .env는 .gitignore로 커밋되지 않음. 키를 채팅·커밋에 절대 노출 금지.
# ============================================================

# ---- 실행 모드 ----
# true  : 키 없이 전체 UX 동작 (가짜 STT/TTS/LLM/OCR)
# false : 키가 있는 provider만 실제 연동, 없는 것은 자동 mock 폴백
MOCK_MODE=true

# ---- CLOVA Studio (LLM, HyperCLOVA X) ----
# 발급: NCP 콘솔에서 CLOVA Studio 이용 신청 → CLOVA Studio 콘솔 접속
#       → [API 키] 메뉴에서 발급 (nv-로 시작하는 키)
CLOVA_STUDIO_API_KEY=

# ---- AI·NAVER API (STT: CSR / TTS: CLOVA Voice Premium) ----
# 발급: NCP 콘솔 → AI·NAVER API → Application 등록
#       → 상품에서 "CLOVA Speech Recognition(CSR)"과 "CLOVA Voice Premium" 선택
#       → 발급된 Client ID / Client Secret 입력
NCP_APIGW_CLIENT_ID=
NCP_APIGW_CLIENT_SECRET=

# ---- CLOVA OCR ----
# 발급: NCP 콘솔 → CLOVA OCR → 도메인 생성 (General 선택)
#       → 도메인의 Secret Key 발급 + APIGW Invoke URL 확인
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# ---- RAG 복지 검색 (기본값으로 동작; 인덱스는 build_index.py로 생성) ----
# RAG_ENABLED=true
# RAG_DATA_DIR=data
# RAG_SCORE_THRESHOLD=0.45        # 실 임베딩 거부 임계값 (P4 평가로 재튜닝)
# RAG_SCORE_THRESHOLD_MOCK=0.15

# ---- 공공데이터포털 복지서비스 API (data.go.kr) ----
# ▼▼ 여기에 키 붙여넣기 ▼▼
# 포털의 두 서비스(중앙부처·지자체) 페이지에 보이는 키는 "같은 계정 키 1개"입니다.
# 페이지마다 Encoding/Decoding 두 값이 보이는데, 그중 "일반 인증키(Decoding)"를 넣으세요.
# (Encoding 키를 넣으면 SERVICE_KEY_IS_NOT_REGISTERED 에러 / 승인 직후엔 반영까지
#  1~2시간 걸릴 수 있음 → 401 Unauthorized면 기다렸다 재시도)
WELFARE_API_KEY=

# 엔드포인트는 서비스마다 2개씩(목록조회/상세조회) 총 4개 — 전부 코드에 기본값 내장이라
# 보통 비워둡니다. 포털 표기가 아래와 달라졌을 때만 주석을 풀고 덮어쓰세요.
# [중앙부처복지서비스 15090532]
#   목록조회 → WELFARE_CENTRAL_LIST_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001/NationalWelfarelistV001
#   상세조회 → WELFARE_CENTRAL_DETAIL_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001/NationalWelfaredetailedV001
# [지자체복지서비스 15108347]
#   목록조회 → WELFARE_LOCAL_LIST_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations/LcgvWelfarelist
#   상세조회 → WELFARE_LOCAL_DETAIL_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations/LcgvWelfaredetailed

# ---- (선택) ncloud CLI용 메인 API 인증키 — 이 앱 실행에는 불필요 ----
# 발급: NCP 콘솔 → 마이페이지 → 계정 관리 → 인증키 관리
NCP_ACCESS_KEY=
NCP_SECRET_KEY=
NCP_REGION=KR

# ---- 앱 설정 (기본값 그대로 두면 됨) ----
APP_HOST=127.0.0.1
APP_PORT=8080
CLOVA_LLM_MODEL=HCX-007
CLOVA_CHAT_MODEL=HCX-005
CLOVA_TTS_VOICE=vmikyung
CLOVA_TTS_SPEED=0   # 음성 속도: -5(빠름) ~ 10(느림), 0=기본
MAX_UPLOAD_MB=5
SESSION_TTL_MIN=120
LOG_LEVEL=INFO
